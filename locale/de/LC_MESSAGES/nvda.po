msgid "Makro Yöneticisi"
msgstr "Makro-Manager"

msgid "Makro kaydı başladı."
msgstr "Makroaufzeichnung gestartet."

msgid "Kayıt durduruldu. {count} olay yakalandı."
msgstr "Aufzeichnung gestoppt. {count} Ereignisse erfasst."

msgid "Oynatılacak geçici makro yok."
msgstr "Kein temporäres Makro zum Abspielen vorhanden."

msgid "Önce kaydı durdurun."
msgstr "Bitte stoppen Sie zuerst die Aufzeichnung."

msgid "Geçici makro oynatılıyor..."
msgstr "Temporäres Makro wird abgespielt..."

msgid "Kayıt otomatik durduruldu."
msgstr "Aufzeichnung automatisch gestoppt."

msgid "Makroyu Düzenle"
msgstr "Makro bearbeiten"

msgid "Makro Adı:"
msgstr "Makroname:"

msgid "Döngü:"
msgstr "Schleife:"

msgid "Durdurana kadar çalıştır"
msgstr "Ausführen, bis es gestoppt wird"

msgid "Oynatma Hızı:"
msgstr "Wiedergabegeschwindigkeit:"

msgid "0.5x (Yavaş)"
msgstr "0.5x (Langsam)"

msgid "1x (Orijinal)"
msgstr "1x (Original)"

msgid "2x (Hızlı)"
msgstr "2x (Schnell)"

msgid "5x (Çok Hızlı)"
msgstr "5x (Sehr schnell)"

msgid "Gecikmesiz"
msgstr "Ohne Verzögerung (Sofort)"

msgid "Güvenlik:"
msgstr "Sicherheit:"

msgid "Sadece '{app_name}' uygulamasında çalışsın"
msgstr "Nur in der Anwendung '{app_name}' ausführen"

msgid "Uygulama kilidi kullanılamaz (Veri yok)"
msgstr "Anwendungssperre nicht verfügbar (Keine Daten)"

msgid "Güncelle"
msgstr "Aktualisieren"

msgid "İptal"
msgstr "Abbrechen"

msgid "İsimsiz Makro"
msgstr "Unbenanntes Makro"

msgid "Kaydedilmiş Makrolar:"
msgstr "Gespeicherte Makros:"

msgid "Henüz makro yok"
msgstr "Noch keine Makros"

msgid "Oynat"
msgstr "Abspielen"

msgid "Düzenle"
msgstr "Bearbeiten"

msgid "Sil"
msgstr "Löschen"

msgid "İçe Aktar (Import)"
msgstr "Makro importieren"

msgid "Dışa Aktar (Export)"
msgstr "Makro exportieren"

msgid "Yeni Makro İşlemi ({count} Olay Yakalandı):"
msgstr "Neuer Makro-Vorgang ({count} Ereignisse erfasst):"

msgid "Yeni Makro"
msgstr "Neues Makro"

msgid "Döngü Sayısı:"
msgstr "Anzahl der Schleifen:"

msgid "Belirli bir uygulamaya bağla"
msgstr "An eine bestimmte Anwendung binden"

msgid "Makroyu Veritabanına Kaydet"
msgstr "Makro in Datenbank speichern"

msgid "Kapat"
msgstr "Schließen"

msgid "Makro başarıyla güncellendi."
msgstr "Makro erfolgreich aktualisiert."

msgid "{name} silindi."
msgstr "{name} gelöscht."

msgid "Makroyu Dışa Aktar"
msgstr "Makro exportieren"

msgid "{name} başarıyla dışa aktarıldı."
msgstr "{name} erfolgreich exportiert."

msgid "Dışa aktarma başarısız oldu."
msgstr "Export fehlgeschlagen."

msgid "Makroyu İçe Aktar"
msgstr "Makro importieren"

msgid "{name} makrosu başarıyla içe aktarıldı."
msgstr "Makro {name} erfolgreich importiert."

msgid "Geçersiz makro dosyası."
msgstr "Ungültige Makrodatei."

msgid "İçe aktarma başarısız oldu."
msgstr "Import fehlgeschlagen."

msgid "{name} başarıyla kaydedildi."
msgstr "{name} erfolgreich gespeichert."

msgid "Güvenlik Uyarısı: Makro '{target_app}' için kilitli. Şu anki: '{current_app}'."
msgstr "Sicherheitswarnung: Makro an '{target_app}' gesperrt. Aktuell: '{current_app}'."

msgid "Makro oynatımı iptal edildi."
msgstr "Makro-Wiedergabe abgebrochen."

msgid "Makro oynatımı tamamlandı."
msgstr "Makro-Wiedergabe abgeschlossen."

msgid "Makro kayıt sürecini başlatır veya devam eden kaydı durdurur."
msgstr "Startet den Makroaufzeichnungsprozess oder stoppt die laufende Aufzeichnung."

msgid "Son kaydedilen veya seçili makroyu oynatır. Oynatma sırasındaysa iptal eder."
msgstr "Spielt das zuletzt aufgezeichnete oder ausgewählte Makro ab. Bricht ab, wenn es gerade abgespielt wird."

msgid "Makro Yöneticisi arayüzünü açar."
msgstr "Öffnet die Makro-Manager-Schnittstelle."

msgid "Makroyu Düzenle (IDE)"
msgstr "Makro bearbeiten (IDE)"

msgid "Şu anki aktif uygulamaya kilitle"
msgstr "An aktuell aktive Anwendung binden"

msgid "Makro Olayları (Tuşlar ve Gecikmeler):"
msgstr "Makro-Ereignisse (Tasten und Verzögerungen):"

msgid "Gecikmeyi Düzenle"
msgstr "Verzögerung bearbeiten"

msgid "Seçili Olayı Sil"
msgstr "Ausgewähltes Ereignis löschen"

msgid "Yukarı Taşı"
msgstr "Nach oben verschieben"

msgid "Aşağı Taşı"
msgstr "Nach unten verschieben"

msgid "Basıldı"
msgstr "Gedrückt"

msgid "Bırakıldı"
msgstr "Losgelassen"

msgid "Gecikme"
msgstr "Verzögerung"

msgid ""
"Yeni gecikme süresini milisaniye (ms) cinsinden girin:\n"
"(Örnek: 1 saniye için 1000)"
msgstr ""
"Geben Sie die neue Verzögerung in Millisekunden (ms) ein:\n"
"(Beispiel: 1000 für 1 Sekunde)"

msgid "Gecikme Düzenle"
msgstr "Verzögerung bearbeiten"

msgid "Gecikme güncellendi."
msgstr "Verzögerung aktualisiert."

msgid "Hata: Sadece rakam giriniz."
msgstr "Fehler: Bitte nur Zahlen eingeben."

msgid "Olay silindi."
msgstr "Ereignis gelöscht."

msgid "Yukarı taşındı."
msgstr "Nach oben verschoben."

msgid "Aşağı taşındı."
msgstr "Nach unten verschoben."

msgid "Oynatılıyor: {name}"
msgstr "Wird abgespielt: {name}"

msgid "Makroyu Oynat: {name}"
msgstr "Makro abspielen: {name}"

msgid "Makro Yöneticisi - Özel Kısayollar"
msgstr "Makro-Manager - Eigene Tastenkombinationen"

msgid "Kaydet"
msgstr "Speichern"

msgid "İçe Aktar"
msgstr "Importieren"

msgid "Dışa Aktar"
msgstr "Exportieren"

msgid "Oynatma Hızı Çarpanı (0 = Gecikmesiz):"
msgstr "Wiedergabegeschwindigkeits-Multiplikator (0 = Sofort):"

msgid "Oynatma Hızı. Hazır değer seçin veya 1.3 gibi kendi hızınızı yazın. 0 gecikmesizdir."
msgstr "Wiedergabegeschwindigkeit. Wählen Sie einen Vorgabewert oder geben Sie einen eigenen ein, z.B. 1.3. 0 ist ohne Verzögerung."

msgid "Durdurana kadar çalıştır (Sonsuz Döngü)"
msgstr "Ausführen bis zum Stopp (Endlosschleife)"

msgid "Uygulama Kilidi Güvenliği"
msgstr "Anwendungssperren-Sicherheit"

msgid "Kaydedilmiş Makrolar Listesi. Çoklu seçim destekler."
msgstr "Liste der gespeicherten Makros. Unterstützt Mehrfachauswahl."

msgid "Makro Olayları Listesi. Shift ve oklarla çoklu seçim yapabilirsiniz."
msgstr "Makro-Ereignisliste. Sie können die Umschalttaste und die Pfeiltasten für eine Mehrfachauswahl verwenden."

msgid "Geri alındı."
msgstr "Rückgängig gemacht."

msgid "İleri alındı."
msgstr "Wiederhergestellt."

msgid "Bas-Çek"
msgstr "Drücken-Loslassen"

msgid "Bekleme"
msgstr "Warten"

msgid "Basılı Tutma"
msgstr "Haltezeit"

msgid "Bekleme Süresi Düzenle"
msgstr "Wartezeit bearbeiten"

msgid "Bekleme süresi güncellendi."
msgstr "Wartezeit aktualisiert."

msgid ""
"Yeni bekleme süresini milisaniye (ms) cinsinden girin:\n"
"(Örnek: 1 saniye için 1000)"
msgstr ""
"Geben Sie die neue Wartezeit in Millisekunden (ms) ein:\n"
"(Beispiel: 1000 für 1 Sekunde)"

msgid "Seçili olaylar silindi."
msgstr "Ausgewählte Ereignisse gelöscht."

msgid "'{name}' makrosu silindi."
msgstr "Makro '{name}' gelöscht."

msgid "{count} makro silindi."
msgstr "{count} Makros gelöscht."

msgid "'{name}' makrosu başarıyla dışa aktarıldı."
msgstr "Makro '{name}' erfolgreich exportiert."

msgid "'{name}' makrosu başarıyla içe aktarıldı."
msgstr "Makro '{name}' erfolgreich importiert."

msgid "'{name}' makrosu başarıyla kaydedildi."
msgstr "Makro '{name}' erfolgreich gespeichert."

msgid "Özel Makro: {name}"
msgstr "Benutzerdefiniertes Makro: {name}"

msgid "Canlı makro kaydı başladı."
msgstr "Live-Makroaufzeichnung gestartet."

msgid "Güvenli makro kaydı başladı. Tuşlar gizleniyor."
msgstr "Sichere Makroaufzeichnung gestartet. Tasten werden ausgeblendet."

msgid "Canlı makro kaydını başlatır veya durdurur. (Tuşlar sisteme işler)"
msgstr "Startet oder stoppt die Live-Makroaufzeichnung. (Tasten werden vom System verarbeitet)"

msgid "Güvenli makro kaydını başlatır. (Tuşlar sistemden gizlenir)"
msgstr "Startet die sichere Makroaufzeichnung. (Tasten werden vor dem System verborgen)"
